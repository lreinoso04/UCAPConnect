{
  "expo": {
    "name": "UCAPConnect",
    "slug": "ucapconnect-mejoras",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ucapconnect",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d47a1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "edu.uapa.ucapconnect.mejoras",
      "associatedDomains": [
        "applinks:ucapconnect.ing.software"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "edu.uapa.ucapconnect.mejoras",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d47a1"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ucapconnect.ing.software",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "owner": "djelia102",
    "extra": {
      "eas": {
        "projectId": "42c3b848-ff65-44b6-976a-d35ee0afba0f"
      }
    }
  }
}
