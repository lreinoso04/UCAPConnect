{
  "expo": {
    "name": "UCAPConnect",
    "slug": "ucapconnect-mejoras",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "ucapconnect",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d47a1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "edu.uapa.ucapconnect.mejoras",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "edu.uapa.ucapconnect.mejoras",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d47a1"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "14a749f4-fff6-4209-a697-759ccb1a19a1"
      }
    },
    "owner": "lreinoso"
  }
}
